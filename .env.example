# --------------------------------------------------
# Aplicacao
# --------------------------------------------------
# Porta local da API NestJS.
PORT=3000

# Nome exibido na aplicacao/logs.
APP_NAME=TimeSlot API

# development | test | production
APP_ENV=development

# URL base da API local.
APP_URL=http://localhost:3000

# --------------------------------------------------
# Banco de dados - Supabase PostgreSQL
# --------------------------------------------------
# DATABASE_URL:
# Use a string de conexao para a aplicacao.
# No Supabase, normalmente prefira a conexao pooled/transaction pooler
# para a aplicacao em runtime.
# Exemplo:
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST-POOLED]:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require&pgbouncer=true&connection_limit=1&connect_timeout=30"

# DIRECT_URL:
# Use a conexao direta para migrations e comandos do Prisma.
# No Supabase, geralmente e a porta 5432.
# Exemplo:
# postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require&pgbouncer=true&connection_limit=1&connect_timeout=30"

# --------------------------------------------------
# JWT
# --------------------------------------------------
# Use uma chave longa e aleatoria em ambientes reais.
JWT_SECRET="troque-esta-chave-por-uma-string-longa-e-segura"

# Exemplos: 1d, 12h, 7d
JWT_EXPIRES_IN=1d

# --------------------------------------------------
# Seed local
# --------------------------------------------------
SEED_ADMIN_NAME="Administrador Local"
SEED_ADMIN_EMAIL="admin@timeslot.local"
SEED_ADMIN_PASSWORD="Admin@123456"

# --------------------------------------------------
# Compatibilidade futura com MySQL
# --------------------------------------------------
# O schema atual do Prisma esta com provider = "postgresql".
# A modelagem foi mantida generica para facilitar migracao futura,
# mas a troca para MySQL exigira alterar o provider do datasource
# e revisar migrations/indices conforme o banco escolhido.

