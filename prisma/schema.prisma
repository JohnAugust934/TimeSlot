generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN        @map("admin")
  RECEPTIONIST @map("recepcionista")
  PROFESSIONAL @map("profissional")
  CLIENT       @map("cliente")

  @@map("usuario_tipo")
}

enum AppointmentStatus {
  SCHEDULED   @map("agendado")
  CONFIRMED   @map("confirmado")
  IN_PROGRESS @map("em_atendimento")
  COMPLETED   @map("concluido")
  CANCELLED   @map("cancelado")
  NO_SHOW     @map("faltou")
  RESCHEDULED @map("remarcado")

  @@map("agendamento_status")
}

enum ConfirmationStatus {
  PENDING   @map("pendente")
  CONFIRMED @map("confirmado")
  DECLINED  @map("recusado")

  @@map("confirmacao_status")
}

enum AppointmentHistoryAction {
  CREATED              @map("criado")
  CONFIRMED            @map("confirmado")
  CONFIRMATION_CHANGED @map("confirmacao_alterada")
  RESCHEDULED          @map("remarcado")
  CANCELLED            @map("cancelado")
  COMPLETED            @map("concluido")
  NO_SHOW              @map("faltou")
  NOTES_CHANGED        @map("observacao_alterada")
  STATUS_CHANGED       @map("status_alterado")

  @@map("historico_acao")
}

enum WaitlistStatus {
  WAITING   @map("aguardando")
  CALLED    @map("chamado")
  CONVERTED @map("convertido")
  CANCELLED @map("cancelado")

  @@map("lista_espera_status")
}

model User {
  id                  String               @id @default(cuid())
  name                String               @map("nome") @db.VarChar(150)
  email               String               @unique @db.VarChar(255)
  passwordHash        String               @map("senha_hash")
  role                UserRole             @map("tipo")
  active              Boolean              @default(true) @map("ativo")
  professional        Professional?
  createdAppointments Appointment[]        @relation("AppointmentCreatedBy")
  appointmentHistory  AppointmentHistory[]
  createdAt           DateTime             @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt           DateTime             @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@map("usuario")
}

model Unit {
  id                String             @id @default(cuid())
  name              String             @map("nome") @db.VarChar(150)
  address           String?            @map("endereco")
  city              String?            @map("cidade") @db.VarChar(120)
  state             String?            @map("estado") @db.VarChar(120)
  active            Boolean            @default(true) @map("ativo")
  professionalUnits ProfessionalUnit[]
  availabilities    Availability[]
  agendaBlocks      AgendaBlock[]
  appointments      Appointment[]
  waitlistEntries   Waitlist[]
  createdAt         DateTime           @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@map("unidade")
}

model Professional {
  id              String                @id @default(cuid())
  fullName        String                @map("nome") @db.VarChar(150)
  category        String?               @map("categoria") @db.VarChar(100)
  specialty       String?               @map("especialidade") @db.VarChar(150)
  phone           String?               @map("telefone") @db.VarChar(30)
  email           String?               @unique @db.VarChar(255)
  userId          String?               @unique @map("usuario_id")
  active          Boolean               @default(true) @map("ativo")
  user            User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  services        ProfessionalService[]
  units           ProfessionalUnit[]
  availabilities  Availability[]
  agendaBlocks    AgendaBlock[]
  appointments    Appointment[]
  waitlistEntries Waitlist[]
  createdAt       DateTime              @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt       DateTime              @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@index([userId], map: "idx_profissional_usuario_id")
  @@index([email], map: "idx_profissional_email")
  @@map("profissional")
}

model Client {
  id              String        @id @default(cuid())
  fullName        String        @map("nome") @db.VarChar(150)
  phone           String?       @map("telefone") @db.VarChar(30)
  email           String?       @db.VarChar(255)
  document        String?       @unique(map: "cliente_documento_unico") @map("documento") @db.VarChar(50)
  birthDate       DateTime?     @map("data_nascimento") @db.Date
  notes           String?       @map("observacoes")
  active          Boolean       @default(true) @map("ativo")
  appointments    Appointment[]
  waitlistEntries Waitlist[]
  createdAt       DateTime      @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@index([email], map: "idx_cliente_email")
  @@index([document], map: "idx_cliente_documento")
  @@map("cliente")
}

model Service {
  id              String                @id @default(cuid())
  name            String                @map("nome") @db.VarChar(120)
  description     String?               @map("descricao")
  durationMinutes Int                   @map("duracao_minutos")
  active          Boolean               @default(true) @map("ativo")
  professionals   ProfessionalService[]
  appointments    Appointment[]
  waitlistEntries Waitlist[]
  createdAt       DateTime              @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt       DateTime              @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@map("servico")
}

model ProfessionalService {
  id             String       @id @default(cuid())
  professionalId String       @map("profissional_id")
  serviceId      String       @map("servico_id")
  price          Decimal?     @map("preco") @db.Decimal(10, 2)
  active         Boolean      @default(true) @map("ativo")
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@unique([professionalId, serviceId], map: "profissional_servico_unico")
  @@index([professionalId], map: "idx_profissional_servico_profissional")
  @@index([serviceId], map: "idx_profissional_servico_servico")
  @@map("profissional_servico")
}

model ProfessionalUnit {
  id             String       @id @default(cuid())
  professionalId String       @map("profissional_id")
  unitId         String       @map("unidade_id")
  active         Boolean      @default(true) @map("ativo")
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  unit           Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@unique([professionalId, unitId], map: "profissional_unidade_unico")
  @@index([professionalId], map: "idx_profissional_unidade_profissional")
  @@index([unitId], map: "idx_profissional_unidade_unidade")
  @@map("profissional_unidade")
}

model Availability {
  id              String       @id @default(cuid())
  professionalId  String       @map("profissional_id")
  unitId          String?      @map("unidade_id")
  weekday         Int          @map("dia_semana") @db.SmallInt
  startTime       DateTime     @map("hora_inicio") @db.Time(6)
  endTime         DateTime     @map("hora_fim") @db.Time(6)
  intervalMinutes Int?         @map("intervalo_minutos")
  active          Boolean      @default(true) @map("ativo")
  professional    Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  unit            Unit?        @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt       DateTime     @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@index([professionalId, weekday], map: "idx_disponibilidade_profissional_dia")
  @@map("disponibilidade")
}

model AgendaBlock {
  id             String       @id @default(cuid())
  professionalId String       @map("profissional_id")
  unitId         String?      @map("unidade_id")
  startsAt       DateTime     @map("data_inicio") @db.Timestamptz(6)
  endsAt         DateTime     @map("data_fim") @db.Timestamptz(6)
  reason         String?      @map("motivo")
  allDay         Boolean      @default(false) @map("dia_inteiro")
  active         Boolean      @default(true) @map("ativo")
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  unit           Unit?        @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@index([professionalId, startsAt, endsAt], map: "idx_bloqueio_profissional_intervalo")
  @@map("bloqueio_agenda")
}

model Appointment {
  id                 String               @id @default(cuid())
  professionalId     String               @map("profissional_id")
  clientId           String               @map("cliente_id")
  serviceId          String               @map("servico_id")
  unitId             String?              @map("unidade_id")
  createdByUserId    String?              @map("criado_por")
  rescheduledFromId  String?              @map("reagendado_de_agendamento_id")
  startsAt           DateTime             @map("data_hora_inicio") @db.Timestamptz(6)
  endsAt             DateTime             @map("data_hora_fim") @db.Timestamptz(6)
  status             AppointmentStatus    @default(SCHEDULED)
  confirmationStatus ConfirmationStatus   @default(PENDING) @map("status_confirmacao")
  notes              String?              @map("observacoes")
  internalNotes      String?              @map("observacoes_internas")
  cancellationReason String?              @map("motivo_cancelamento")
  cancelledAt        DateTime?            @map("cancelado_em") @db.Timestamptz(6)
  professional       Professional         @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  client             Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  service            Service              @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  unit               Unit?                @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdByUser      User?                @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rescheduledFrom    Appointment?         @relation("AppointmentRescheduleChain", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo      Appointment[]        @relation("AppointmentRescheduleChain")
  history            AppointmentHistory[]
  createdAt          DateTime             @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@index([professionalId, startsAt], map: "idx_agendamento_profissional_inicio")
  @@index([clientId, startsAt], map: "idx_agendamento_cliente_inicio")
  @@index([status], map: "idx_agendamento_status")
  @@map("agendamento")
}

model AppointmentHistory {
  id            String                   @id @default(cuid())
  appointmentId String                   @map("agendamento_id")
  userId        String?                  @map("usuario_id")
  action        AppointmentHistoryAction @map("acao")
  description   String?                  @map("descricao")
  metadata      Json?                    @map("metadata")
  appointment   Appointment              @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user          User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime                 @default(now()) @map("criado_em") @db.Timestamptz(6)

  @@index([appointmentId, createdAt(sort: Desc)], map: "idx_historico_agendamento_data")
  @@map("historico_agendamento")
}

model Waitlist {
  id              String         @id @default(cuid())
  clientId        String         @map("cliente_id")
  professionalId  String?        @map("profissional_id")
  serviceId       String?        @map("servico_id")
  unitId          String?        @map("unidade_id")
  preferredDate   DateTime?      @map("data_preferida") @db.Date
  preferredPeriod String?        @map("periodo_preferido") @db.VarChar(40)
  notes           String?        @map("observacoes")
  status          WaitlistStatus @default(WAITING)
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  professional    Professional?  @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  service         Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  unit            Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now()) @map("criado_em") @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  @@index([professionalId], map: "idx_lista_espera_profissional")
  @@index([status], map: "idx_lista_espera_status")
  @@map("lista_espera")
}
